# Variables de entorno para producción
# Copia este archivo como .env y configura los valores

# Base de datos MongoDB (usa MongoDB Atlas)
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/pokemonapp

# Puerto (Render lo asigna automáticamente)
PORT=10000

# Claves VAPID para notificaciones push (genera nuevas para producción)
VAPID_PUBLIC=tu_clave_publica_vapid
VAPID_PRIVATE=tu_clave_privada_vapid

# Clave secreta para JWT (genera una segura)
JWT_SECRET=tu_clave_secreta_muy_segura_para_jwt